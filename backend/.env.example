# Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/library-management
# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/library-management

# JWT Secret Keys
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Razorpay Credentials (Get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Admin Default Credentials (First time setup)
ADMIN_EMAIL=admin@library.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Admin

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: Email Configuration (for Super Admin OTP and notifications)
# Uncomment and configure these to enable email functionality
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password
# 
# For Gmail setup:
# 1. Enable 2-Factor Authentication in your Google Account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated App Password (not your regular password)
# 4. EMAIL_PASS should be your Gmail App Password (16 characters)
